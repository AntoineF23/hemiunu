{
  "name": "@hemiunu/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n worker,client -c yellow,green \"tsx watch src/server/index.ts\" \"vite\"",
    "dev:worker": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@fontsource-variable/newsreader": "^5.1.0",
    "@fontsource/noto-sans-egyptian-hieroglyphs": "^5.1.0",
    "@hemiunu/agent-core": "workspace:*",
    "@hemiunu/format": "workspace:*",
    "@hemiunu/mcp": "workspace:*",
    "@hemiunu/memory": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "highlight.js": "^11.10.0",
    "hono": "^4.6.0",
    "lucide-react": "^0.460.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
