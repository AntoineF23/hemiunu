{
  "name": "hemiunu",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "bin": { "hemiunu": "bin/hemiunu.mjs", "hemiunu-web": "bin/hemiunu-web.mjs" },
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx apps/cli/src/index.tsx",
    "web": "node bin/hemiunu-web.mjs",
    "smoke": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx apps/eval/src/smoke.ts",
    "cap": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx apps/eval/src/capability.ts",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
