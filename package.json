{
  "name": "hemiunu",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "hemiunu": "bin/hemiunu.mjs",
    "hemiunu-web": "bin/hemiunu-web.mjs"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx apps/cli/src/index.tsx",
    "web": "node bin/hemiunu-web.mjs",
    "build:release": "node scripts/build-release.mjs",
    "prepare": "husky",
    "smoke": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx apps/eval/src/smoke.ts",
    "cap": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx apps/eval/src/capability.ts",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --import tsx --test \"packages/**/*.test.ts\""
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  }
}
