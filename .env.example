# Copy to .env (or let `hemiunu` first-run setup write ~/.hemiunu/.env for you).
# .env is gitignored.

# --- The brain (Claude main loop) ---
# Your Anthropic API key. By default Hemiunu talks to Anthropic directly.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: route the brain through an Anthropic-COMPATIBLE gateway/proxy
# (LiteLLM, Bedrock/Vertex gateway, etc.) instead of Anthropic direct.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com

# Main / synthesis model (the agent's brain).
HEMIUNU_MODEL=claude-opus-4.8
# Retrieval tier: the cheaper model the `researcher` subagent runs on.
# NB: claude-haiku-4.5 rejects the `effort` param the SDK sends — use Sonnet/Opus.
HEMIUNU_MODEL_RESEARCH=claude-sonnet-4.6
# Extended thinking budget in tokens. 0/unset = disabled (cheaper, works everywhere).
HEMIUNU_THINKING_BUDGET=0

# --- Other models for the `ask_model` tool (bring your own; all optional) ---
# Add a key for each provider you want the agent to be able to consult.
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=...
# XAI_API_KEY=...
# DEEPSEEK_API_KEY=...
# MISTRAL_API_KEY=...
# If your ANTHROPIC_BASE_URL gateway is OpenAI-compatible, ask_model can use it
# as the `proxy` provider with the same ANTHROPIC_API_KEY — no extra key needed.

# --- MCP servers ---
# Add MCP servers from inside the app (or by editing ~/.hemiunu/mcp.json).
# Any secrets they need are set as env vars here and referenced as ${VAR}.

# --- Context management ---
HEMIUNU_CONTEXT_WINDOW=200000
HEMIUNU_COMPACT_THRESHOLD=0.5
# Per-tool-result budget in tokens. Results bigger than this are truncated
# (with a notice) before entering context, so fat tool outputs (e.g. large
# search dumps or file reads) don't saturate the window. Default 6000.
HEMIUNU_TOOL_RESULT_BUDGET=6000
