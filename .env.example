# Copy to .env, or let `hemiunu` first-run setup write ~/.hemiunu/.env for you.
# The in-app Settings (API keys / Gateway UI) also write these values for you,
# so hand-editing is optional. .env is gitignored.

# --- Provider keys (bring your own; ANY ONE unlocks that provider's models) ---
# None are required if you use a keyless local Ollama. Add a key for each
# provider you want available as the brain, a subagent tier, or via ask_model.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=...
# XAI_API_KEY=...
# DEEPSEEK_API_KEY=...
# MISTRAL_API_KEY=...

# --- Gateway (LiteLLM / OpenRouter / vLLM) ---
# A gateway is a first-class option: one key can front many models at once. The
# in-app Settings can Test & discover a gateway's models and register them for
# you. This key is used by the shipped LiteLLM-routed models (gpt-4o,
# deepseek-v3, qwen3-235b-instruct, mistral-medium).
# LITELLM_API_KEY=...
# Base URL of your gateway. The shipped LiteLLM-routed models default to a
# placeholder host, so point them at your own gateway here (or set each entry's
# baseURL in ~/.hemiunu/models.json).
# LITELLM_BASE_URL=https://your-gateway.example.com/v1

# Optional: route the Claude entries through an Anthropic-compatible gateway.
# Setting this AND putting your gateway key in ANTHROPIC_API_KEY routes the Claude
# models through the gateway; that is a valid single-key setup.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com

# --- Model selection ---
# Main / synthesis model id (the brain). Unset or unusable falls back to the
# first available registry model.
# HEMIUNU_MODEL=claude-opus-4.8
# The cheaper retrieval tier the `researcher` subagent runs on.
# HEMIUNU_MODEL_RESEARCH=claude-sonnet-4.6

# --- Context management ---
# Fraction of the (per-model) context window at which history auto-compacts.
HEMIUNU_COMPACT_THRESHOLD=0.5
# Per-tool-result budget in tokens. Results bigger than this are truncated (with
# a notice) before entering context, so fat tool outputs (large search dumps or
# file reads) do not saturate the window.
HEMIUNU_TOOL_RESULT_BUDGET=60000
# Extended-thinking budget in tokens. 0/unset = off (cheaper, works everywhere).
HEMIUNU_THINKING_BUDGET=0
# Context windows are per-model in the registry. This global override exists but
# is rarely needed.
# HEMIUNU_CONTEXT_WINDOW=200000

# --- MCP servers ---
# Add MCP servers from inside the app (or by editing ~/.hemiunu/mcp.json). Any
# secrets they need are set as env vars here and referenced as ${VAR}.

# --- OpenTelemetry tracing (opt-in; off by default) ---
# When on, every turn / step / model call / tool call / subagent is emitted as
# an OTel span to YOUR collector over the standard OTLP env contract — so a
# teammate running Hemiunu sees its traces in the observability stack they
# already have. Enable by setting HEMIUNU_OTEL=1 or an OTLP endpoint below.
# HEMIUNU_OTEL=1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20...   # e.g. for a SaaS backend
# OTEL_SERVICE_NAME=hemiunu
# Record prompt/output CONTENT on spans (default: 1). Set 0 for metadata-only.
# HEMIUNU_OTEL_RECORD_CONTENT=1
# Anonymization: the actor is pseudonymous (a random, persisted instance id — no
# host/user identity). Override it with a team-chosen pseudonym if you like.
# HEMIUNU_OTEL_ACTOR=team-alpha
# Content redaction level: secrets (default) | pii | off | all. `secrets` keeps
# content but masks API keys/tokens; `pii` also masks emails/phones; `all` drops
# content attributes entirely.
# HEMIUNU_OTEL_REDACT=secrets
# Extra redaction regexes (one per line) applied to recorded content.
# HEMIUNU_OTEL_REDACT_PATTERNS=

# --- Optional / advanced ---
# Model used to auto-title conversations (defaults to a cheap registry entry).
# HEMIUNU_TITLE_MODEL=
# Log the content-free wire shape on a provider 4xx, for debugging only.
# HEMIUNU_WIRE_DEBUG=1
# GitHub OAuth App client id for /github device-flow sign-in (client id is public).
# HEMIUNU_GITHUB_CLIENT_ID=
# Cloudflare Pages deploy (deploy_prototype / /cloudflare).
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
