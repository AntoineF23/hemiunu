# Copy to .env and fill in your LiteLLM key. .env is gitignored.
ANTHROPIC_BASE_URL=https://models.thiga.co
ANTHROPIC_API_KEY=sk-your-litellm-key-here

# Model (as exposed by the proxy): claude-opus-4.8 | claude-sonnet-4.6 | claude-haiku-4.5
HEMIUNU_MODEL=claude-opus-4.8

# Extended thinking budget in tokens. 0 (or unset) = thinking disabled (cheaper,
# works on every model). Set e.g. 8000 to enable reasoning (use with Opus).
HEMIUNU_THINKING_BUDGET=0

# Context management. Auto-compaction summarizes earlier history once context
# reaches the threshold fraction of the window. Lower the window for smaller models.
HEMIUNU_CONTEXT_WINDOW=200000
HEMIUNU_COMPACT_THRESHOLD=0.5
